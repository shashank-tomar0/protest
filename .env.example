# Stand With Sonam Wangchuk — Environment Variables
# Copy this to .env and fill in your keys

# === Resend (email forms) ===
# Sign up at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx
# Where form submissions get emailed to
CONTACT_EMAIL=hello@standwithsonam.org

# === Razorpay (donations) ===
# Sign up at https://razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
